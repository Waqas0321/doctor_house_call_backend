# MongoDB
MONGODB_URI=mongodb://localhost:27017/doctor-house-calls

# Auth
JWT_SECRET=your-secret

# Email (optional). If unset, booking confirmation skips SMTP instead of connecting to localhost.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASS=
# ADMIN_EMAIL=info@doctorhousecalls.ca

# Geocoding — pick ONE approach:
# (A) No key: omit both keys below → OpenStreetMap / Nominatim (free, rate-limited; fine for dev/small traffic)
# (B) Google: set GEOCODING_API_KEY (or GOOGLE_MAPS_API_KEY) from Google Cloud Console → Geocoding API enabled
# GEOCODING_API_KEY=
# GOOGLE_MAPS_API_KEY=
# GEOCODING_PROVIDER=google
# Force OSM even if you have a key:
# GEOCODING_PROVIDER=openstreetmap
# OSM_SERVER=https://nominatim.openstreetmap.org
# Nominatim usage policy: set a contact email + identifiable User-Agent
# NOMINATIM_CONTACT_EMAIL=you@yourdomain.com
# GEOCODING_USER_AGENT=YourApp/1.0 (you@yourdomain.com)
# Admin-only fallback if address text cannot be geocoded (default Winnipeg):
# GEOCODING_FALLBACK_LAT=49.8951
# GEOCODING_FALLBACK_LNG=-97.1384

# FCM / Firebase Admin (push). Admins must register devices: POST /api/auth/device
# FCM_DEVICE_MAX_AGE_DAYS=365
