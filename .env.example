# MongoDB
MONGODB_URI=mongodb://localhost:27017/doctor-house-calls

# Auth
JWT_SECRET=your-secret

# Geocoding — pick ONE approach:
# (A) No key: omit both keys below → OpenStreetMap / Nominatim (free, rate-limited; fine for dev/small traffic)
# (B) Google: set GEOCODING_API_KEY (or GOOGLE_MAPS_API_KEY) from Google Cloud Console → Geocoding API enabled
# GEOCODING_API_KEY=
# GOOGLE_MAPS_API_KEY=
# GEOCODING_PROVIDER=google
# Force OSM even if you have a key:
# GEOCODING_PROVIDER=openstreetmap
# OSM_SERVER=https://nominatim.openstreetmap.org
